'1 https://lichess.org/training/0000D'
if in_backrank_wall(king, pawn, pawn2, pawn3)
ve attack_and_through(rook2, rook3, queen, rook4) 
  if evades_attack_non_confrontational(queen, queen2, rook3) 
    if check_king_with_block_no_capture_no_evade(rook3, rook5, king)
      if blocks(knight, $knight2, rook5, king)
        if checkmate(rook5, rook6, king) [cond]
  if evades_with_cover_block(queen, queen3, rook3, $knight2)
    if captures_hanging(queen4, queen3_queen5)
  if sacrifices_with_exchange(queen3, rook3_queen4, bishop, bishop2) [win]

###


def hangs_to(From, Captured_To, AttackFrom)
  move(From, Captured)
  capture(AttackFrom, To, Captured)

def exchanges_hanging(From, Captured_To, From2, To2)
  capture(From, To, Captured)
  no_defense(To)
  capture(From2, To2, To)



def exchanges(From, Captured_To, From2, To2)
  capture(From, To, Captured)
  capture(From2, To2, To)

def defends(From, To)
  defend(From, To)

def attacks_through(From, To, Through)
  attack_through(From, To, Through)

def blocks_check_defended_by(From, To, DefendFrom, AttackFrom, AttackTo)
  move(From, To)
  defend(DefendFrom, To)
  attack_through(AttackFrom, AttackTo, To)
  

def checks(From, To, King)
  move(From, To)
  attack(To, King)

def no_cover(From, To, NoCover)
  move(From, To)
  no_attack(To, NoCover)

def attacks(From, To, AttackTo)
  move(From, To)
  attack(To, AttackTo)

def has_eye_king(From, To, King)
  attack(From, To)
  attack(King, To)

def sacrifices_with_exchange(From, Captured_To, From2, To2)
  capture(From, To, Captured)
  capture(From2, To2, To)



def evades_with_cover_block(From, To, EvadeFrom, CoverTo)
  move(From, To)
  no_attack(EvadeFrom, To)
  attack(To, CoverTo)



def blocks(From, To, AttackFrom, AttackTo)
  move(From, To)
  attack_through(AttackFrom, AttackTo, To)



def in_backrank_wall(King, A, B, C)
  backrank_wall(King, A, B, C)

def attack_and_through(From, To, AttackTo, AttackThrough)
  move(From, To)
  attack(To, AttackTo)
  attack_through(To, AttackThrough, AttackTo)
  opposite(To, AttackTo)
 
 
def evades_attack_non_confrontational(From, To, AttackFrom)
  move(From, To)
  no_attack(AttackFrom, To)


def check_king_with_block_no_capture_no_evade(From, To, King)
  move(From, To)
  attack(To, King)
  no_king_evades(King)
  no_captures(To)
  no_push_blocks_check(To, King)

  
def checkmate_with_capture(From, Captured_To, King)
  capture(From, To, Captured)
  attack(To, King)
  no_king_evades(King)
  no_captures(To)
  no_blocks_check(To, King)
  no_push_blocks_check(To, King)


  
def checkmate(From, To, King)
  move(From, To)
  attack(To, King)
  no_king_evades(King)
  no_captures(To)
  no_blocks_check(To, King)
  no_push_blocks_check(To, King)


def captures(From, Captured_To)
  capture(From, To, Captured)

def captures_hanging(From, Captured_To)
  no_defense(Captured)
  capture(From, To, Captured)